  "erDesign": {
    "model": {
      "uid": 2,
      "erCode": "/* Entities */\n\nentity USERS {\n    id_pk\n    email_unique\n    username_unique\n    password_hash\n    full_name\n    role\n    country_code\n    birth_date\n    created_at\n    updated_at\n}\n\nentity USER_LANGUAGES {\n    user_id_fk\n    language_code\n    user_id_language_code_pk\n}\n\nentity USER_PREFERENCES {\n    id_pk\n    user_id_fk_unique\n    theme\n    font_size\n    ui_language\n    updated_at\n}\n\nentity USER_SESSIONS {\n    id_pk\n    user_id_fk\n    session_token_unique\n    ip\n    user_agent\n    device_label\n    expires_at\n    created_at\n}\n\nentity AUTH_CHALLENGES {\n    id_pk\n    user_id_fk\n    purpose\n    channel\n    challenge_token_hash_unique\n    expires_at\n    consumed_at\n    created_at\n}\n\nentity PUBLISHERS {\n    id_pk\n    name_unique\n}\n\nentity CATALOG_ITEMS {\n    id_pk\n    type\n    fulfillment_type\n    publisher_id_fk\n    age_rating_min\n    release_date\n    price\n    currency\n    isbn\n    source\n    external_provider\n    external_id\n    avg_rating\n    views_count\n    created_at\n    updated_at\n}\n\nentity CATALOG_ITEM_TRANSLATIONS {\n    id_pk\n    item_id_fk\n    language_code\n    title\n    description\n    content_path\n    content_format\n    item_id_language_code_unique\n}\n\nentity SERIES {\n    id_pk\n    name\n    type\n}\n\nentity SERIES_ENTRIES {\n    id_pk\n    series_id_fk\n    item_id_fk\n    volume_no\n    chapter_no\n    entry_order\n    series_id_item_id_unique\n}\n\nentity ITEM_MEDIA {\n    id_pk\n    item_id_fk\n    language_code\n    media_type\n    storage_path\n    mime_type\n    sort_order\n}\n\nentity AUTHORS {\n    id_pk\n    full_name\n    role\n}\n\nentity ITEM_AUTHORS {\n    item_id_fk\n    author_id_fk\n    item_id_author_id_pk\n}\n\nentity CATEGORIES {\n    id_pk\n    name_unique\n}\n\nentity ITEM_CATEGORIES {\n    item_id_fk\n    category_id_fk\n    item_id_category_id_pk\n}\n\nentity USER_LISTS {\n    id_pk\n    user_id_fk\n    name\n    is_system\n    created_at\n    user_id_name_unique\n}\n\nentity USER_LIST_ITEMS {\n    id_pk\n    list_id_fk\n    item_id_fk\n    added_at\n    list_id_item_id_unique\n}\n\nentity LIBRARY_ITEMS {\n    id_pk\n    user_id_fk\n    item_id_fk\n    source\n    added_at\n    user_id_item_id_source_unique\n}\n\nentity ORDERS {\n    id_pk\n    user_id_fk\n    status\n    total_amount\n    created_at\n}\n\nentity ORDER_ITEMS {\n    id_pk\n    order_id_fk\n    item_id_fk\n    unit_price\n    quantity\n}\n\nentity PAYMENTS {\n    id_pk\n    order_id_fk\n    provider\n    provider_tx_id\n    status\n    paid_at\n}\n\nentity ITEM_LICENSES {\n    item_id_pk_fk\n    available_copies\n    updated_at\n}\n\nentity COMMENTS {\n    id_pk\n    user_id_fk\n    item_id_fk\n    body\n    rating\n    created_at\n    updated_at\n}\n\nentity ITEM_LIKES {\n    user_id_fk\n    item_id_fk\n    created_at\n    user_id_item_id_pk\n}\n\nentity HIGHLIGHTS {\n    id_pk\n    user_id_fk\n    item_id_fk\n    language_code\n    locator_start\n    locator_end\n    selected_text\n    note\n    created_at\n}\n\nentity READING_PROGRESS {\n    id_pk\n    user_id_fk\n    item_id_fk\n    language_code\n    locator\n    percentage\n    last_read_at\n    user_id_item_id_unique\n}\n\n/* Relationships */\n\nrelationship USERS_USER_LANGUAGES (\n    USERS: one..many,\n    USER_LANGUAGES: one..one\n) {\n}\n\nrelationship USERS_USER_PREFERENCES (\n    USERS: one..one,\n    USER_PREFERENCES: one..one\n) {\n}\n\nrelationship USERS_USER_SESSIONS (\n    USERS: one..many,\n    USER_SESSIONS: one..one\n) {\n}\n\nrelationship USERS_AUTH_CHALLENGES (\n    USERS: one..many,\n    AUTH_CHALLENGES: one..one\n) {\n}\n\nrelationship USERS_ORDERS (\n    USERS: one..many,\n    ORDERS: one..one\n) {\n}\n\nrelationship USERS_LIBRARY_ITEMS (\n    USERS: one..many,\n    LIBRARY_ITEMS: one..one\n) {\n}\n\nrelationship USERS_USER_LISTS (\n    USERS: one..many,\n    USER_LISTS: one..one\n) {\n}\n\nrelationship USERS_COMMENTS (\n    USERS: one..many,\n    COMMENTS: one..one\n) {\n}\n\nrelationship USERS_ITEM_LIKES (\n    USERS: one..many,\n    ITEM_LIKES: one..one\n) {\n}\n\nrelationship USERS_HIGHLIGHTS (\n    USERS: one..many,\n    HIGHLIGHTS: one..one\n) {\n}\n\nrelationship USERS_READING_PROGRESS (\n    USERS: one..many,\n    READING_PROGRESS: one..one\n) {\n}\n\nrelationship PUBLISHERS_CATALOG_ITEMS (\n    PUBLISHERS: one..many,\n    CATALOG_ITEMS: zero..one\n) {\n}\n\nrelationship CATALOG_ITEMS_TRANSLATIONS (\n    CATALOG_ITEMS: one..many,\n    CATALOG_ITEM_TRANSLATIONS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_MEDIA (\n    CATALOG_ITEMS: one..many,\n    ITEM_MEDIA: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_AUTHORS (\n    CATALOG_ITEMS: one..many,\n    ITEM_AUTHORS: one..one\n) {\n}\n\nrelationship AUTHORS_ITEM_AUTHORS (\n    AUTHORS: one..many,\n    ITEM_AUTHORS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_CATEGORIES (\n    CATALOG_ITEMS: one..many,\n    ITEM_CATEGORIES: one..one\n) {\n}\n\nrelationship CATEGORIES_ITEM_CATEGORIES (\n    CATEGORIES: one..many,\n    ITEM_CATEGORIES: one..one\n) {\n}\n\nrelationship USER_LISTS_USER_LIST_ITEMS (\n    USER_LISTS: one..many,\n    USER_LIST_ITEMS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_USER_LIST_ITEMS (\n    CATALOG_ITEMS: one..many,\n    USER_LIST_ITEMS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_LIBRARY_ITEMS (\n    CATALOG_ITEMS: one..many,\n    LIBRARY_ITEMS: one..one\n) {\n}\n\nrelationship ORDERS_ORDER_ITEMS (\n    ORDERS: one..many,\n    ORDER_ITEMS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_ORDER_ITEMS (\n    CATALOG_ITEMS: one..many,\n    ORDER_ITEMS: one..one\n) {\n}\n\nrelationship ORDERS_PAYMENTS (\n    ORDERS: one..many,\n    PAYMENTS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_ITEM_LICENSES (\n    CATALOG_ITEMS: zero..one,\n    ITEM_LICENSES: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_COMMENTS (\n    CATALOG_ITEMS: one..many,\n    COMMENTS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_ITEM_LIKES (\n    CATALOG_ITEMS: one..many,\n    ITEM_LIKES: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_HIGHLIGHTS (\n    CATALOG_ITEMS: one..many,\n    HIGHLIGHTS: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_READING_PROGRESS (\n    CATALOG_ITEMS: one..many,\n    READING_PROGRESS: one..one\n) {\n}\n\nrelationship SERIES_SERIES_ENTRIES (\n    SERIES: one..many,\n    SERIES_ENTRIES: one..one\n) {\n}\n\nrelationship CATALOG_ITEMS_SERIES_ENTRIES (\n    CATALOG_ITEMS: one..many,\n    SERIES_ENTRIES: one..one\n) {\n}",
